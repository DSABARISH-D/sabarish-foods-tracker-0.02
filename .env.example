# Sabarish Foods — Environment Variables
# Copy this file to .env and fill in your values

# ── Supabase ────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → Project → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Google Sheets ────────────────────────────────────────
# Spreadsheet ID: from your Sheet URL → docs.google.com/spreadsheets/d/THIS_PART/edit
EXPO_PUBLIC_SHEETS_SPREADSHEET_ID=your-spreadsheet-id-here

# API Key: https://console.cloud.google.com → APIs → Google Sheets API → Credentials
EXPO_PUBLIC_SHEETS_API_KEY=your-sheets-api-key-here
